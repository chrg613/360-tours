# API Configuration
VITE_API_BASE_URL=http://localhost:3600/api/v1
# Deprecated fallback (read only if VITE_API_BASE_URL is unset):
# VITE_API_URL=http://localhost:3600/api/v1
VITE_API_TIMEOUT=30000

# Supabase Configuration (for direct client-side auth)
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Feature Flags
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_VR_MODE=true
VITE_ENABLE_AI_FEATURES=true

# Storage Configuration
VITE_MAX_UPLOAD_SIZE_MB=50
VITE_ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp

# Auth Configuration
# Override the Google OAuth redirect URL (defaults to window.location.origin/auth/callback).
# Set this for Docker / reverse-proxy setups where the browser origin differs from the
# intended callback URL. Example: VITE_AUTH_REDIRECT_URL=http://localhost:3000
# VITE_AUTH_REDIRECT_URL=

# App Configuration
VITE_APP_NAME=360 Viewer
VITE_APP_VERSION=1.0.0

# Splat Lab - 3D Gaussian Splatting Pipeline
# Get your key from app.daytona.io → Settings → API Keys
VITE_DAYTONA_API_KEY=
VITE_SPLAT_BUCKET=splat-jobs
